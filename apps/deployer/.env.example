# RabbitMQ - Message queue for build/deploy jobs
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Redis - Real-time log streaming and pub/sub
REDIS_URL=redis://localhost:6379

# AWS Region (e.g., us-east-1, eu-west-1, ap-south-1)
AWS_REGION=your-aws-region

# ECS Configuration
ECS_CLUSTER_NAME=your-ecs-cluster-name
ALB_LISTENER_ARN=arn:aws:elasticloadbalancing:region:account-id:listener/...

# Networking - VPC and subnets for ECS tasks
VPC_ID=vpc-xxxxxxxxxxxxxxxxx
SUBNET_A=subnet-xxxxxxxxxxxxxxxxx
SUBNET_B=subnet-xxxxxxxxxxxxxxxxx
ECS_SG_ID=sg-xxxxxxxxxxxxxxxxx

# IAM Role for ECS task execution
TASK_EXECUTION_ROLE_ARN=arn:aws:iam::account-id:role/your-ecs-execution-role

# ECR Registry (format: account-id.dkr.ecr.region.amazonaws.com)
ECR_REGISTRY=your-account-id.dkr.ecr.your-region.amazonaws.com

# PostgreSQL Database
# Format: postgres://username:password@host:port/database?sslmode=disable
DATABASE_URL=postgres://user:pass@localhost:5432/hatch?sslmode=disable