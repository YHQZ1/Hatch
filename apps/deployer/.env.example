# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Redis
REDIS_URL=redis://localhost:6379

# AWS Configuration
AWS_REGION=ap-south-1

# ECS Configuration
ECS_CLUSTER_NAME=hatch-cluster
ALB_LISTENER_ARN=arn:aws:elasticloadbalancing:ap-south-1:your-account-id:listener/app/your-alb/your-listener-id
BASE_DOMAIN=your-domain.com

# Networking
VPC_ID=vpc-your-vpc-id
SUBNET_A=subnet-your-subnet-a
SUBNET_B=subnet-your-subnet-b
ECS_SG_ID=sg-your-security-group-id

# IAM
TASK_EXECUTION_ROLE_ARN=arn:aws:iam::your-account-id:role/hatch-ecs-task-execution

# ECR
ECR_REGISTRY=your-account-id.dkr.ecr.ap-south-1.amazonaws.com

# Database
DATABASE_URL=postgres://user:pass@localhost:5432/hatch?sslmode=disable