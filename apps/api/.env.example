# Server Configuration
PORT=8080
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:8080/auth/callback

# JWT Authentication
JWT_SECRET=your-strong-jwt-secret-min-32-chars

# PostgreSQL Database
DATABASE_URL=postgres://user:pass@localhost:5432/hatch?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# AWS Configuration
AWS_REGION=ap-south-1
ECR_REGISTRY=your-account-id.dkr.ecr.ap-south-1.amazonaws.com
ECR_REPOSITORY=hatch-builds

# Webhook Configuration
WEBHOOK_BASE_URL=https://your-domain.com