# Server Configuration
PORT=8080

# GitHub OAuth
# Create an OAuth App at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:8080/auth/callback

# JWT Authentication - Use a strong random string (min 32 chars)
JWT_SECRET=your-strong-jwt-secret-key-here

# PostgreSQL Database
# Format: postgres://username:password@host:port/database?sslmode=disable
DATABASE_URL=postgres://user:pass@localhost:5432/hatch?sslmode=disable

# Redis - Session and log streaming
REDIS_URL=redis://localhost:6379

# RabbitMQ - Message queue
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# AWS Configuration
AWS_REGION=your-aws-region
ECR_REGISTRY=your-account-id.dkr.ecr.your-region.amazonaws.com
ECR_REPOSITORY=your-ecr-repository-name

# AWS Credentials (optional - uses IAM role if running on EC2/ECS)
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key