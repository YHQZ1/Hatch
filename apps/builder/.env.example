# RabbitMQ - Message queue for build jobs
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Redis - Real-time log streaming
REDIS_URL=redis://localhost:6379

# AWS Region (e.g., us-east-1, eu-west-1, ap-south-1)
AWS_REGION=your-aws-region

# ECR Registry (format: your-account-id.dkr.ecr.your-region.amazonaws.com)
ECR_REGISTRY=your-account-id.dkr.ecr.your-region.amazonaws.com

# ECR Repository name for build images
ECR_REPOSITORY=your-ecr-repository-name